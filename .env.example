# =============================================================
# loltrix_be 환경변수 템플릿
# 복사해서 사용: cp .env.example .env.development
# 실제 값이 든 .env.* 파일은 절대 커밋하지 않는다 (.gitignore 적용됨).
# =============================================================

# --- 서버 ---
NODE_ENV=development
PORT=19901

# --- Database (PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false
# 커넥션 풀 (선택 — 미설정 시 코드 기본값)
# DB_MAX_CONNECTIONS=10
# DB_IDLE_TIMEOUT=30000
# DB_CONNECTION_TIMEOUT=5000

# --- Security ---
COOKIE_SECRET=change-me-random-string

# --- LoL ---
LOL_SEASON=2026

# --- Discord OAuth / 봇 검증 ---
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_REDIRECT_URI=http://localhost:19901/api/auth/callback
DISCORD_BOT_SECRET=change-me-shared-with-bot

# =============================================================
# Riot Tournament API (TRC-225 토너먼트코드 MVP)
# =============================================================

# Riot 개발자 포털에서 발급한 API 키. dev 키는 24시간마다 만료 → 재발급 후 교체.
# 키 재발급 시 provider 재등록 필요 (tournament.service의 forceReregister).
RIOT_API_KEY=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# true면 tournament-stub-v5(목업) 사용 — dev 키 MVP 단계는 항상 true.
# 프로덕션 키 승인 후에만 false로 전환.
RIOT_TOURNAMENT_STUB=true

# 콜백 경로 시크릿: POST /api/callback/riot/{이값} 로 수신.
# 추측 불가능한 랜덤 문자열 사용 (예: openssl rand -hex 32). 유출 시 즉시 교체.
RIOT_CALLBACK_SECRET=change-me-openssl-rand-hex-32

# provider 등록 시 Riot에 전달하는 공개 콜백 URL (등록 시에만 사용).
# 시크릿 경로까지 포함한 전체 URL이어야 함. 로컬 stub 테스트는 localhost 가능.
RIOT_CALLBACK_URL=https://dev-api.gmok.kr/api/callback/riot/change-me-openssl-rand-hex-32

# (선택) provider 등록 리전 / tournament 이름 — 미설정 시 KR / trcgg-mvp
# RIOT_TOURNAMENT_REGION=KR
# RIOT_TOURNAMENT_NAME=trcgg-mvp

# (선택) 라우팅 호스트 오버라이드 — 미설정 시 tournament=americas, match=asia(KR)
# RIOT_TOURNAMENT_HOST=americas.api.riotgames.com
# RIOT_MATCH_HOST=asia.api.riotgames.com

# --- 콜백 시뮬레이터 (scripts/simulate-riot-callback.ts, 로컬 전용) ---
# CALLBACK_BASE_URL=http://localhost:19901
# SIM_CODE=발급해둔_토너먼트코드
# SIM_GAME_ID=1234567890
# SIM_REGION=KR

# =============================================================
# 봇 콜백 (TRC-226 토너먼트코드 봇 연동)
# =============================================================

# 적재 성공(신규) 후 봇에게 "다음 코드 게시"를 지시할 때 호출하는 봇의 로컬 콜백 서버 URL.
# 봇과 백엔드는 같은 호스트에 있으므로 기본 127.0.0.1. 봇의 BOT_CALLBACK_PORT와 포트가 일치해야 함.
# 미설정 시 http://127.0.0.1:19902 사용. 인증은 DISCORD_BOT_SECRET(x-discord-bot 헤더)을 역방향 재사용.
BOT_CALLBACK_URL=http://127.0.0.1:19902
