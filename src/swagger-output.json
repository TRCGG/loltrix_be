    "/api/statistics/{guildId}/users": {
      "get": {
        "tags": [
          "Statistics"
        ],
        "summary": "유저별 게임 통계",
        "description": "특정 길드 내 유저들의 게임 통계(승률, 판수 등)를 다양한 필터로 조회합니다.",
        "parameters": [
          {
            "name": "guildId",
            "in": "path",
            "description": "길드 ID",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "year",
            "in": "query",
            "description": "년도 (YYYY)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "month",
            "in": "query",
            "description": "월 (1~12)",
            "schema": {
